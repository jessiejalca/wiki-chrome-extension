{
  "manifest_version": 3,
  "name": "Wiki Chrome Extension",
  "version": "1.0.0",
  "description": "WikiRoulette",
  "action": {
    "default_popup": "popup.html",
    "default_title": "WikiRoulette"
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://*.wikipedia.org/*"]
}